# Bliss Project Git Ignore

# --- SENSITIVE DATA (CRITICAL) ---
# Prevents your API keys, database strings, and secrets from leaking
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.jks
*.p8
*.p12
*.mobileprovision

# --- DEPENDENCIES ---
node_modules/
.pnp
.pnp.js

# --- EXPO & METRO ---
.expo/
dist/
web-build/
metro-cache/
.metro-health-check*
expo-env.d.ts

# --- GENERATED NATIVE FOLDERS ---
# Only ignore these if you are using Expo Prebuild / Continuous Native Generation
/ios
/android

# --- BUNDLES & BUILDS ---
*.jsbundle
*.tsbuildinfo

# --- DEBUG & LOGS ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
logs
*.log

# --- SYSTEM FILES ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# --- IDE / EDITOR ---
.vscode/
.idea/
*.swp
*.swo
.project
.settings/

# --- MISC ---
.kotlin/
*.orig.*
app-example/